{
  "env": {
    "CLAUDE_DISABLE_ADAPTATIVE_THINKING": "1"
  },
  "model": "opus[1m]",
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "notify-send -u normal -i utilities-terminal \"Claude Code ($(basename \"$PWD\"))\" 'Task Completed'; paplay /usr/share/sounds/freedesktop/stereo/complete.oga 2>/dev/null || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "notify-send -u critical -i dialog-question \"Claude Code ($(basename \"$PWD\"))\" 'Input Required'; paplay /usr/share/sounds/freedesktop/stereo/dialog-warning.oga 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /home/bruno/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {},
  "effortLevel": "high",
  "autoCompactWindow": 200000,
  "advisorModel": "opus",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "autoCompactEnabled": true
}
